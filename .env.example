# Copy to `.env.local` and fill in. `.env.local` is gitignored — never commit real keys.

# ElevenLabs API key — ONLY used by scripts/gen_audio.py to (re)generate the
# voice/sfx/music in public/audio. The game itself ships those audio files, so
# you do NOT need this key just to run or build the game. Get one at
# https://elevenlabs.io → Profile → API Keys.
ELEVEN_KEY=

# Optional: dev server port (defaults to 5173). Used by vite.config.ts.
# PORT=5173
